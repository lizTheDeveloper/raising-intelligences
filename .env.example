# Required
OPENROUTER_API_KEY=sk-or-...

# Optional — restrict CORS to your deployment domain (defaults to http://localhost:5173)
ALLOWED_ORIGIN=https://yourdomain.com

# Optional — "standard" | "cerebras" | "premium" (defaults to "cerebras" if CEREBRAS_API_KEY is set, else "standard")
MODEL_TIER=cerebras

# Optional — Cerebras API for high-throughput narrative generation (~1000 tok/s)
# Without this key, MODEL_TIER must be "standard" or "premium" (OpenRouter only)
CEREBRAS_API_KEY=csk-...

# Optional — omit to run with in-memory storage
DATABASE_URL=postgres://postgres:postgres@localhost:5432/raising_intelligences

# Optional — omit to disable Langfuse tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=

# Intro image generation uses OPENROUTER_API_KEY (already required above)
# Run: OPENROUTER_API_KEY=... node scripts/generate-intro-images.mjs

# Optional
PORT=3000
NODE_ENV=development
