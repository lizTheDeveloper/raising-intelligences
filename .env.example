# Required
OPENROUTER_API_KEY=sk-or-...

# Optional — restrict CORS to your deployment domain (defaults to http://localhost:5173)
ALLOWED_ORIGIN=https://yourdomain.com

# Optional — defaults to "standard"
MODEL_TIER=standard

# Optional — omit to run with in-memory storage
DATABASE_URL=postgres://postgres:postgres@localhost:5432/raising_intelligences

# Optional — omit to disable Langfuse tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=

# Optional — Scenario API for generating intro image pool (build-time only)
# Run: node scripts/generate-intro-images.mjs
SCENARIO_API_KEY=api_...
SCENARIO_API_SECRET=...

# Optional
PORT=3000
NODE_ENV=development
