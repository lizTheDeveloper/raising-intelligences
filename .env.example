# Required
OPENROUTER_API_KEY=sk-or-...

# Optional — restrict CORS to your deployment domain (defaults to http://localhost:5173)
ALLOWED_ORIGIN=https://yourdomain.com

# Optional — "standard" | "cerebras" | "premium" (defaults to "cerebras" if CEREBRAS_API_KEY is set, else "standard")
MODEL_TIER=cerebras

# Optional — Cerebras API for high-throughput narrative generation (~1000 tok/s)
# Without this key, MODEL_TIER must be "standard" or "premium" (OpenRouter only)
CEREBRAS_API_KEY=csk-...

# Optional — omit to run with in-memory storage
DATABASE_URL=postgres://postgres:postgres@localhost:5432/raising_intelligences

# Recommended — enables the primary content-safety layer: OpenAI's free
# Moderation API (has a purpose-trained "sexual/minors" category) checks every
# parent message before it reaches the kid-LLM. Without this key, moderation
# falls back to the contextual LLM classifier alone (safety/moderation.ts).
OPENAI_API_KEY=sk-...

# Optional — omit to disable Langfuse tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=

# Intro image generation uses OPENROUTER_API_KEY (already required above)
# Run: OPENROUTER_API_KEY=... node scripts/generate-intro-images.mjs

# Optional — enables the admin dashboard at /raising-intelligences/admin
# Requires DATABASE_URL to be set (admin only works with Postgres)
ADMIN_TOKEN=your-secret-admin-token

# Optional — the shared Multiverse Games Stripe checkout service (ceo/stripe-webhook).
# Defaults to the production endpoint; only override for local testing against a
# different stripe-webhook instance.
STRIPE_WEBHOOK_CHECKOUT_URL=https://multiversestudios.xyz/stripe/create-checkout-session

# Optional
PORT=3000
NODE_ENV=development
